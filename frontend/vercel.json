{
  "redirects": [
    {
      "source": "/umoja-mgmt",
      "destination": "https://umoja-skills.onrender.com/umoja-mgmt/",
      "permanent": false
    },
    {
      "source": "/umoja-mgmt/:path*",
      "destination": "https://umoja-skills.onrender.com/umoja-mgmt/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
