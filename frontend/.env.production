# Production API URL — set VITE_API_URL as a Vercel Environment Variable
# pointing to your Render backend, e.g.:
# VITE_API_URL=https://umoja-backend.onrender.com/api
#
# Do NOT commit the real URL here; set it in the Vercel dashboard instead.
VITE_API_URL=https://REPLACE_WITH_YOUR_RENDER_BACKEND.onrender.com/api
